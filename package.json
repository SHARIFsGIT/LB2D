{
  "name": "lb2d-platform",
  "version": "1.0.0",
  "description": "Learn Bangla to Deutsch - A comprehensive language learning platform",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:all": "npm run lint:backend && npm run lint:frontend",
    "deploy:production": "cd backend && ./scripts/production-deploy.sh",
    "setup:admin": "cd backend && node create-admin.js",
    "setup:db": "cd backend && node setup-database.js",
    "clean:all": "rm -rf backend/node_modules backend/dist frontend/node_modules frontend/build node_modules",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "health:check": "curl -f http://localhost:5000/health && curl -f http://localhost:3000"
  },
  "keywords": [
    "language-learning",
    "german",
    "bengali",
    "education",
    "e-learning",
    "node.js",
    "react",
    "typescript",
    "mongodb"
  ],
  "author": "LB2D Development Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/lb2d-platform.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/lb2d-platform/issues"
  },
  "homepage": "https://github.com/your-username/lb2d-platform#readme",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "optionalDependencies": {
    "pm2": "^5.4.2"
  }
}